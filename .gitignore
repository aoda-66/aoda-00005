# ====================== Python 后端忽略 ======================
# Python字节码
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# 虚拟环境
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# 日志、缓存
*.log
*.swp
*.swo
.cache/
.pytest_cache/

# 数据库、本地配置
*.sqlite
*.db
.env          # 环境变量（密钥、数据库地址绝对不能提交）
.env.local
config.ini
secrets.json

# 打包产物
dist/
build/
*.egg-info/
*.egg

# ====================== Vue 前端忽略 ======================
# Node依赖
node_modules/

# 打包产物
frontend/dist/
frontend/build/

# 本地环境配置
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# 编辑器、缓存
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 操作系统文件
.DS_Store
Thumbs.db